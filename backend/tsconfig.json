{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // ADD THIS:
    "verbatimModuleSyntax": false
},
"include": ["src/**/*.ts"],
"exclude": ["node_modules", "**/*.spec.ts"]

}
